# ── OpenRouter (modelos de texto gratuitos: Gemma 4, Llama 3.3) ──────────────
# Regístrate en https://openrouter.ai → API Keys → crear clave
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Servidor Express ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL (historial de generaciones) ───────────────────────────────────
# Si no tienes Postgres, el historial falla silenciosamente — el resto funciona
DB_HOST=localhost
DB_PORT=5432
DB_NAME=IW2
DB_USER=postgres
DB_PASSWORD=tu_password

# ── Strapi CMS (galería de publicaciones) ────────────────────────────────────
# URL donde corre Strapi (por defecto puerto 1337)
STRAPI_URL=http://localhost:1337
# Token de API: Admin Strapi → Settings → API Tokens → crear token Full Access
STRAPI_API_TOKEN=tu_token_de_strapi_aqui
